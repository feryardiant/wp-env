{
  "name": "@feryardiant/wordpress-env",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "license": "MIT",
  "workspaces": {
    "packages": [
      "packages/*"
    ],
    "catalog": {
      "commit-and-tag-version": "^12.7.1"
    }
  },
  "scripts": {
    "format": "biome format --write",
    "lint": "biome check",
    "postinstall": "if [ -z \"$CI\" ]; then simple-git-hooks; fi",
    "release": "bunx commit-and-tag-version -s"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@tsconfig/bun": "^1.0.10",
    "@types/bun": "1.3.10",
    "commit-and-tag-version": "catalog:",
    "lint-staged": "^16.4.0",
    "simple-git-hooks": "^2.13.1"
  },
  "overrides": {
    "@types/node": "24.9.1"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "commit-and-tag-version": {},
  "simple-git-hooks": {
    "commit-msg": "bunx commitlint --edit $1",
    "pre-commit": "bunx lint-staged --allow-empty"
  },
  "lint-staged": {
    "*.{css,jsonc,ts}": [
      "biome format --write --no-errors-on-unmatched"
    ],
    "docker/mu-plugins/*.php": [
      "sh -c 'composer format:packages -- \"$@\"; [ \"$?\" -eq 0 ] || [ \"$?\" -eq 1 ]' --"
    ],
    "packages/**/*.php": [
      "sh -c 'composer format:packages -- \"$@\"; [ \"$?\" -eq 0 ] || [ \"$?\" -eq 1 ]' --"
    ],
    "tests/**/*.php": [
      "sh -c 'composer format:tests -- \"$@\"; [ \"$?\" -eq 0 ] || [ \"$?\" -eq 1 ]' --"
    ],
    "{package,tsconfig}.json": [
      "biome format --write --no-errors-on-unmatched"
    ]
  }
}
